# Root-level env for docker-compose.yml.
# Copy to .env — Docker Compose reads it automatically from the same directory.

COMPOSE_PROJECT_NAME=medcalc

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=medcalc
POSTGRES_PORT=5432

# Ports
FRONTEND_PORT=3000
BACKEND_PORT=3001

# Runtime
NODE_ENV=development
